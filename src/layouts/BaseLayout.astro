---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'lys open source system' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href="/">lys</a>
        <nav class="nav">
          <a href="/learn">学习路径</a>
          <a href="/articles">文章</a>
          <a href="/projects">项目</a>
          <a href="/weekly">周更</a>
          <a href="/roadmap">路线图</a>
          <a href="/about">关于</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
