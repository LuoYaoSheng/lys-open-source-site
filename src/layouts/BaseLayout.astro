---
import '../styles/global.css';
import { siteMeta } from '../data/site';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'lys open source system — 从真实开源项目学习 BLE 与 IoT',
  image,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, siteMeta.siteUrl);
const ogImage = image || '/favicon.svg';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteMeta.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteMeta.siteUrl)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Extra SEO -->
    <meta name="keywords" content={siteMeta.keywords} />
    <meta name="author" content={siteMeta.author} />
    <meta name="theme-color" content={siteMeta.themeColor} />
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href="/">lys</a>
        <nav class="nav">
          <a href="/learn">学习路径</a>
          <a href="/articles">文章</a>
          <a href="/projects">项目</a>
          <a href="/weekly">周更</a>
          <a href="/roadmap">路线图</a>
          <a href="/about">关于</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
