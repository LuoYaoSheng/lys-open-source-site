---
import '../styles/global.css';
import { siteMeta } from '../data/site';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = siteMeta.description,
  image,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, siteMeta.siteUrl);
const ogImage = image || '/favicon.svg';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteMeta.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteMeta.siteUrl)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Extra SEO -->
    <meta name="keywords" content={siteMeta.keywords} />
    <meta name="author" content={siteMeta.author} />
    <meta name="theme-color" content={siteMeta.themeColor} />

    <!-- Anti-flicker: dark mode -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var toggle = document.getElementById('theme-toggle');
    if (!toggle) return;
    var html = document.documentElement;
    var iconLight = document.querySelector('.theme-icon-light');
    var iconDark = document.querySelector('.theme-icon-dark');

    function updateIcons() {
      var isDark = html.classList.contains('dark');
      if (iconLight) iconLight.style.display = isDark ? 'none' : 'inline';
      if (iconDark) iconDark.style.display = isDark ? 'inline' : 'none';
    }

    updateIcons();

    toggle.addEventListener('click', function () {
      html.classList.toggle('dark');
      var isDark = html.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcons();
    });
  });
</script>
