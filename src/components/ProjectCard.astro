---
interface Props {
  name: string;
  summary: string;
  status: string;
  repo: string;
  bestFor?: string;
  ctaLabel?: string;
}

const { name, summary, status, repo, bestFor, ctaLabel = '查看仓库' } = Astro.props;
---

<article class="project-card">
  <div class="project-meta">
    <span class="status-chip">{status}</span>
  </div>
  <h3>{name}</h3>
  <p>{summary}</p>
  {bestFor && <p class="best-for"><strong>Best for</strong> {bestFor}</p>}
  <a href={repo} target="_blank" rel="noreferrer">{ctaLabel}</a>
</article>
