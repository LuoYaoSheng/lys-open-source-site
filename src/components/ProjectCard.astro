---
interface Props {
  name: string;
  summary: string;
  status: string;
  repo: string;
  ctaLabel?: string;
}

const { name, summary, status, repo, ctaLabel = '查看仓库' } = Astro.props;
---

<article class="doc-project-card">
  <span class="status-chip">{status}</span>
  <h3>{name}</h3>
  <p>{summary}</p>
  <a href={repo} target="_blank" rel="noreferrer">{ctaLabel} →</a>
</article>
