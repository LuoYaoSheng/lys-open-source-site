---
import LandingLayout from '../layouts/LandingLayout.astro';
import '../styles/landing.css';
import { features, quickStart, siteMeta, toolVisuals, visualEntries } from '../data/site';
---

<LandingLayout title="lys 开源项目集合">
  <section class="hero">
    <span class="eyebrow">开源项目</span>
    <h1>从 BLE 调试到 IoT 平台，<br/>从想法到可用的工具</h1>
    <p class="hero-copy">{siteMeta.description}</p>
    <div class="cta-row" style="justify-content: center;">
      <a class="button-primary" href="/docs/getting-started">快速开始</a>
      <a class="button-secondary" href="/projects">浏览项目</a>
    </div>
  </section>

  <section class="section">
    <div class="section-head" style="text-align: center;">
      <span class="eyebrow">核心项目</span>
      <h2>三条主线</h2>
    </div>
    <div class="section-grid">
      {features.map((feature) => (
        <article class="feature-card">
          <span class="tag">{feature.tag}</span>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
          <a href={feature.href} target={feature.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">
            {feature.ctaLabel || (feature.href.startsWith('http') ? '打开入口' : '浏览全部')}
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head" style="text-align: center;">
      <span class="eyebrow">真实入口</span>
      <h2>先看真实截图，再决定是否深入</h2>
      <p>主线项目已经有可直接进入的截图和二维码，不需要先读完仓库结构再开始。</p>
    </div>
    <div class="visual-entry-grid">
      {visualEntries.map((entry) => (
        <article class="visual-entry-card">
          <div class="visual-entry-main">
            <span class="tag">{entry.badge}</span>
            <h3>{entry.name}</h3>
            <p>{entry.summary}</p>
            <img class="visual-entry-shot" src={entry.image} alt={entry.name} loading="lazy" />
            <div class="visual-entry-actions">
              <a href={entry.primaryHref} target="_blank" rel="noreferrer">{entry.primaryLabel}</a>
              <a href={entry.secondaryHref} target="_blank" rel="noreferrer">{entry.secondaryLabel}</a>
            </div>
          </div>
          <div class="visual-entry-qr">
            <img src={entry.qr} alt={entry.qrLabel} loading="lazy" />
            <strong>{entry.qrLabel}</strong>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head" style="text-align: center;">
      <span class="eyebrow">快速上手</span>
      <h2>三步了解这套开源体系</h2>
    </div>
    <div class="section-grid">
      {quickStart.steps.map((step, index) => (
        <article class="feature-card">
          <span class="tag">步骤 {index + 1}</span>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
          <a href={step.href} target={step.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">
            {step.ctaLabel || (step.href.startsWith('http') ? '打开入口' : '查看')}
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head" style="text-align: center;">
      <span class="eyebrow">工具入口</span>
      <h2>桌面工具主线</h2>
      <p>数据库、Redis 和 SSH 运维这三条工具线已经有独立项目站入口。</p>
    </div>
    <div class="tool-visual-grid">
      {toolVisuals.map((tool) => (
        <a class="tool-visual-card" href={tool.href} target="_blank" rel="noreferrer">
          <img src={tool.image} alt={tool.name} loading="lazy" />
          <strong>{tool.name}</strong>
        </a>
      ))}
    </div>
  </section>

  <div class="quick-links">
    <a class="quick-link" href="/docs/getting-started">
      <strong>快速开始</strong>
      <span>了解项目生态与上手路径</span>
    </a>
    <a class="quick-link" href="/docs/guides">
      <strong>技术指南</strong>
      <span>架构解析与实战教程</span>
    </a>
    <a class="quick-link" href="/changelog">
      <strong>更新日志</strong>
      <span>最近做了什么变更</span>
    </a>
    <a class="quick-link" href="/roadmap">
      <strong>路线图</strong>
      <span>接下来计划做什么</span>
    </a>
  </div>
</LandingLayout>
