---
import LandingLayout from '../layouts/LandingLayout.astro';
import '../styles/landing.css';
import { features, quickStart, siteMeta } from '../data/site';
---

<LandingLayout title="lys Open Source System">
  <section class="hero">
    <span class="eyebrow">Open Source</span>
    <h1>BLE, IoT & Developer Tools</h1>
    <p class="hero-copy">{siteMeta.description}</p>
    <div class="cta-row" style="justify-content: center;">
      <a class="button-primary" href="/docs/getting-started">Get Started</a>
      <a class="button-secondary" href="/projects">View Projects</a>
    </div>
  </section>

  <section class="section">
    <div class="section-head" style="text-align: center;">
      <span class="eyebrow">Featured</span>
      <h2>Core Projects</h2>
    </div>
    <div class="section-grid">
      {features.map((feature) => (
        <article class="feature-card">
          <span class="tag">{feature.tag}</span>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
          <a href={feature.href} target={feature.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">
            {feature.href.startsWith('http') ? 'View Repo' : 'Browse'}
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head" style="text-align: center;">
      <span class="eyebrow">Quick Start</span>
      <h2>Get Going in 3 Steps</h2>
    </div>
    <div class="section-grid">
      {quickStart.steps.map((step, index) => (
        <article class="feature-card">
          <span class="tag">Step {index + 1}</span>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
          <a href={step.href}>Open</a>
        </article>
      ))}
    </div>
  </section>

  <div class="quick-links">
    <a class="quick-link" href="/docs/getting-started">
      <strong>Getting Started</strong>
      <span>Setup & first run</span>
    </a>
    <a class="quick-link" href="/docs/guides">
      <strong>Guides</strong>
      <span>Technical articles</span>
    </a>
    <a class="quick-link" href="/changelog">
      <strong>Changelog</strong>
      <span>Latest updates</span>
    </a>
    <a class="quick-link" href="/roadmap">
      <strong>Roadmap</strong>
      <span>What's coming next</span>
    </a>
  </div>
</LandingLayout>
