---
import BaseLayout from '../layouts/BaseLayout.astro';
import { articleCollections, articlePlan, learnerPromises } from '../data/site';
---

<BaseLayout title="Articles | lys Open Source System">
  <section class="section">
    <div class="section-head">
      <div>
        <span class="eyebrow">Articles</span>
        <h1>文章不是附属物，而是学习入口本身。</h1>
        <p>这里的文章对应真实项目，不是脱离代码的空泛教程。更好的顺序通常是：先试、再读、再回仓库。</p>
      </div>
    </div>

    <div class="section-grid">
      <article class="section-card article-plan-card">
        <h3>更新节奏</h3>
        <ul class="list">
          {articlePlan.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="section-card article-plan-card">
        <h3>阅读这类文章时你可以期待什么</h3>
        <ul class="list">
          {learnerPromises.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>

    {articleCollections.map((collection) => (
      <section class="section">
        <div class="section-head">
          <div>
            <span class="eyebrow">{collection.title}</span>
            <h2>{collection.title}</h2>
            <p>{collection.intro}</p>
          </div>
        </div>
        <div class="section-grid">
          {collection.items.map((item) => (
            <article class="project-card article-card">
              <div class="meta-row">
                <span class="status-chip">{item.level}</span>
                <span class="meta-pill">{item.readTime}</span>
                <span class="meta-pill">{item.tag}</span>
              </div>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <a href={item.href} target="_blank" rel="noreferrer">Read</a>
            </article>
          ))}
        </div>
      </section>
    ))}
  </section>
</BaseLayout>
