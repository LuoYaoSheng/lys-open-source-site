---
import DocLayout from '../layouts/DocLayout.astro';
import '../styles/doc.css';
import { roadmap } from '../data/site';
---

<DocLayout title="Roadmap | lys Open Source System">
  <h1>Roadmap</h1>
  <p>
    What is being worked on, what is planned, and what has been shipped.
    This reflects the current development priorities, not an internal schedule.
  </p>

  <div class="roadmap-section">
    <h2>{roadmap.quarter}</h2>
    <p>{roadmap.theme}</p>
  </div>

  <div class="roadmap-section">
    <h3>In Progress</h3>
    <ul class="roadmap-list">
      {roadmap.inProgress.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>

  <div class="roadmap-section">
    <h3>Planned</h3>
    <ul class="roadmap-list planned">
      {roadmap.planned.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>

  <div class="roadmap-section">
    <h3>Done</h3>
    <ul class="roadmap-list done">
      {roadmap.done.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>
</DocLayout>
