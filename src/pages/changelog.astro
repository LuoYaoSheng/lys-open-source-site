---
import DocLayout from '../layouts/DocLayout.astro';
import '../styles/doc.css';
import { changelog } from '../data/site';
---

<DocLayout title="Changelog | lys Open Source System">
  <h1>Changelog</h1>
  <p>
    A chronological record of notable changes, improvements, and milestones across the lys open-source ecosystem.
  </p>

  {changelog.map((entry) => (
    <div class="changelog-entry">
      <div class="changelog-meta">
        <span class="status-chip">{entry.version}</span>
        <span class="mono">{entry.date}</span>
      </div>
      <h3>{entry.title}</h3>
      <ul class="changelog-changes">
        {entry.changes.map((change) => (
          <li>{change}</li>
        ))}
      </ul>
    </div>
  ))}
</DocLayout>
