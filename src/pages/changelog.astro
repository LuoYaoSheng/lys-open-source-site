---
import DocLayout from '../layouts/DocLayout.astro';
import '../styles/doc.css';
import { changelog } from '../data/site';
---

<DocLayout title="更新日志 | lys 开源项目集合">
  <h1>更新日志</h1>
  <p>
    lys 开源项目生态中的重要变更、改进和里程碑的按时间记录。
  </p>

  {changelog.map((entry) => (
    <div class="changelog-entry">
      <div class="changelog-meta">
        <span class="status-chip">{entry.version}</span>
        <span class="mono">{entry.date}</span>
      </div>
      <h3>{entry.title}</h3>
      <ul class="changelog-changes">
        {entry.changes.map((change) => (
          <li>{change}</li>
        ))}
      </ul>
    </div>
  ))}
</DocLayout>
