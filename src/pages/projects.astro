---
import DocLayout from '../layouts/DocLayout.astro';
import '../styles/doc.css';
import { projectGroups } from '../data/site';
---

<DocLayout title="项目 | lys 开源项目集合">
  <h1>项目</h1>
  <p>
    所有开源项目按类别组织。每个项目链接到其仓库，并提供简要描述和当前状态。
  </p>

  {projectGroups.map((group) => (
    <div class="project-group" id={group.items[0]?.id}>
      <h2>{group.title}</h2>
      <p>{group.intro}</p>
      <div class="doc-section-grid">
        {group.items.map((item) => (
          <article class="doc-project-card">
            <span class="status-chip">{item.status}</span>
            <h3>{item.name}</h3>
            <p>{item.summary}</p>
            <a href={item.repo} target="_blank" rel="noreferrer">查看仓库 →</a>
          </article>
        ))}
      </div>
    </div>
  ))}
</DocLayout>
