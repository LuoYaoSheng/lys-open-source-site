---
import DocLayout from '../layouts/DocLayout.astro';
import '../styles/doc.css';
import { projectGroups } from '../data/site';
---

<DocLayout title="Projects | lys Open Source System">
  <h1>Projects</h1>
  <p>
    All open-source projects organized by category. Each project links to its repository
    and provides a brief description of its purpose and current status.
  </p>

  {projectGroups.map((group) => (
    <div class="project-group" id={group.items[0]?.id}>
      <h2>{group.title}</h2>
      <p>{group.intro}</p>
      <div class="doc-section-grid">
        {group.items.map((item) => (
          <article class="doc-project-card">
            <span class="status-chip">{item.status}</span>
            <h3>{item.name}</h3>
            <p>{item.summary}</p>
            <a href={item.repo} target="_blank" rel="noreferrer">View Repository →</a>
          </article>
        ))}
      </div>
    </div>
  ))}
</DocLayout>
